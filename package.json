  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "oracledb": "^6.8.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/oracledb": "^6.10.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
